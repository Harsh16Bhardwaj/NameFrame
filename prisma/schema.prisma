generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EventStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum CertificateTemplateRole {
  DEFAULT
  FIRST
  SECOND
  THIRD
}

enum AwardPosition {
  FIRST
  SECOND
  THIRD
}

enum EmailProvider {
  NODEMAILER
  RESEND
  SENDGRID
}

enum DeliveryMode {
  SINGLE
  BATCH
  ALL
  SCHEDULED
}

enum DeliveryJobStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum DeliveryAttemptStatus {
  SENT
  FAILED
  BOUNCED
  DEFERRED
}

enum PaymentProvider {
  RAZORPAY
}

enum PaymentStatus {
  CREATED
  CAPTURED
  FAILED
  REFUNDED
}

enum PlanCode {
  PRO_MONTHLY
  PRO_ANNUAL
}

enum UserRole {
  FREE
  PRO
}

model User {
  id                  String   @id
  email               String   @unique
  name                String
  role                UserRole @default(FREE)
  isPro               Boolean  @default(false)
  razorpayCustomerId  String?
  groqApiKeyEncrypted String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  events          Event[]
  templates       CertificateTemplate[]
  emailTemplates  EmailTemplate[]
  paymentRecords  PaymentRecord[]
}

model Event {
  id                   String      @id @default(uuid())
  title                String
  description          String?
  imageUrl             String?
  organizationName     String?
  organizationLogoUrl  String?
  certificateTitle     String?
  location             String?
  emailContentText     String?
  status               EventStatus @default(DRAFT)
  scheduledSendAt      DateTime?
  emailTemplateId      String?
  userId               String
  templateId           String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  user              User                        @relation(fields: [userId], references: [id])
  template          CertificateTemplate?        @relation("DefaultEventTemplate", fields: [templateId], references: [id])
  emailTemplate     EmailTemplate?              @relation(fields: [emailTemplateId], references: [id])
  participants      Participant[]
  templateBindings  EventCertificateTemplate[]
  awardAssignments  EventAwardAssignment[]
  deliveryJobs      DeliveryJob[]
  certificateIssues CertificateIssue[]
  insightSnapshot   InsightSnapshot?

  @@index([userId, createdAt])
}

model CertificateTemplate {
  id               String   @id @default(cuid())
  name             String
  backgroundUrl    String
  editorConfigJson Json
  userId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User                       @relation(fields: [userId], references: [id])
  events           Event[]                    @relation("DefaultEventTemplate")
  eventBindings    EventCertificateTemplate[]
  certificateIssues CertificateIssue[]
}

model EventCertificateTemplate {
  id         String                  @id @default(cuid())
  eventId    String
  templateId String
  role       CertificateTemplateRole @default(DEFAULT)
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  event    Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  template CertificateTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@unique([eventId, role])
  @@index([templateId])
}

model EventAwardAssignment {
  id            String        @id @default(cuid())
  eventId       String
  participantId String
  position      AwardPosition
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([eventId, participantId])
  @@index([eventId, position])
}

model EmailTemplate {
  id            String   @id @default(cuid())
  userId        String
  name          String
  subject       String
  bodyHtml      String?
  bodyText      String?
  variablesJson Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  events Event[]
}

model Participant {
  id               String   @id @default(uuid())
  name             String
  email            String
  eventId          String
  certificateUrl   String?
  qrCodeUrl        String?
  emailed          Boolean  @default(false)
  participated     Boolean  @default(false)
  verificationCode String?  @unique
  certificateHash  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  event            Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  awardAssignments EventAwardAssignment[]
  deliveryAttempts DeliveryAttempt[]
  certificateIssues CertificateIssue[]

  @@unique([eventId, email])
  @@index([eventId, createdAt])
}

model CertificateIssue {
  id               String                  @id @default(uuid())
  eventId          String
  participantId    String
  templateId       String
  role             CertificateTemplateRole @default(DEFAULT)
  certificateUrl   String?
  qrCodeUrl        String?
  verificationCode String                  @unique
  certificateHash  String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant Participant         @relation(fields: [participantId], references: [id], onDelete: Cascade)
  template    CertificateTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@unique([eventId, participantId, role])
  @@index([participantId, createdAt])
  @@index([eventId, role])
}

model DeliveryJob {
  id           String            @id @default(uuid())
  eventId      String
  provider     EmailProvider
  mode         DeliveryMode
  status       DeliveryJobStatus @default(PENDING)
  scheduledFor DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  batchSize    Int               @default(50)
  lastCursor   String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  event    Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attempts DeliveryAttempt[]

  @@index([eventId, createdAt])
  @@index([status, scheduledFor])
}

model DeliveryAttempt {
  id                String                @id @default(uuid())
  participantId     String
  jobId             String
  provider          EmailProvider
  status            DeliveryAttemptStatus
  attemptNo         Int
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime              @default(now())

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  job         DeliveryJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([participantId, attemptNo])
  @@index([jobId, status])
}

model PaymentRecord {
  id                     String          @id @default(uuid())
  userId                 String
  provider               PaymentProvider @default(RAZORPAY)
  providerPaymentId      String          @unique
  providerSubscriptionId String?
  status                 PaymentStatus
  plan                   PlanCode
  amount                 Int
  currency               String          @default("INR")
  createdAt              DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model InsightSnapshot {
  id                String   @id @default(uuid())
  eventId           String   @unique
  totalParticipants Int
  participatedCount Int
  sentCount         Int
  failedCount       Int
  deliveryRate      Float
  participationRate Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
